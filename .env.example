# ===== Google API =====
# Шлях до JSON-файлу сервісного акаунту (створити в Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# ID папки на Drive, звідки беремо аудіо (з URL папки)
SOURCE_DRIVE_FOLDER_ID=

# ID робочої папки на Drive (туди копіюємо аудіо + кладемо транскрипти)
WORK_DRIVE_FOLDER_ID=


# ID робочої таблиці (куди записуємо результати — створиться при першому запуску, якщо порожньо)
WORK_SHEET_ID=

# ===== Транскрибація =====
# whisper_local | openai_api
TRANSCRIPTION_BACKEND=whisper_local

# Для локального whisper: tiny | base | small | medium | large-v3
WHISPER_MODEL=medium
# cpu | cuda | auto
WHISPER_DEVICE=auto

# Якщо використовуєте OpenAI API
OPENAI_API_KEY=

# ===== LLM для аналізу транскриптів =====
# Локальний Ollama. Має бути запущений: `ollama serve`
# Модель завантажується командою: `ollama pull qwen2.5:7b`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ===== Налаштування =====
LOG_LEVEL=INFO
